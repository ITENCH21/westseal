# ─── Django ──────────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=замените-на-надёжный-ключ
DJANGO_DEBUG=0
SITE_URL=https://euro-seal.ru
ALLOWED_HOSTS=euro-seal.ru,www.euro-seal.ru
CSRF_TRUSTED_ORIGINS=https://euro-seal.ru,https://www.euro-seal.ru

# ─── Telegram-бот ────────────────────────────────────────────────────────────
# 1. Создайте бота через @BotFather → получите токен
TELEGRAM_BOT_TOKEN=1234567890:ваш-токен-от-botfather

# 2. Напишите боту /start в личке (@Ivan_2manof должен первым написать боту).
#    Потом откройте: https://api.telegram.org/bot<TOKEN>/getUpdates
#    Найдите "chat":{"id":XXXXXXXXX} — это и есть ваш TELEGRAM_ADMIN_CHAT_ID
TELEGRAM_ADMIN_CHAT_ID=123456789

# 3. Придумайте случайный SECRET и зарегистрируйте вебхук:
#    https://api.telegram.org/bot<TOKEN>/setWebhook
#      ?url=https://euro-seal.ru/support/telegram/webhook/?secret=ВАШ_SECRET
TELEGRAM_WEBHOOK_SECRET=придумайте-случайную-строку

# ─── Email (резервный канал) ──────────────────────────────────────────────────
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=587
EMAIL_HOST_USER=info@euro-seal.ru
EMAIL_HOST_PASSWORD=пароль
DEFAULT_FROM_EMAIL=info@euro-seal.ru
DEFAULT_TO_EMAIL=info@euro-seal.ru

# ─── Аналитика ───────────────────────────────────────────────────────────────
GA4_ID=G-XXXXXXXXXX
YANDEX_METRIKA_ID=XXXXXXXX
